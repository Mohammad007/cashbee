# --- Core ---
SECRET_KEY=change-me-in-production
JWT_SECRET=change-me-jwt-secret
JWT_EXPIRY_DAYS=30

# --- Admin login (used by admin panel) ---
ADMIN_EMAIL=admin@cashbee.app
ADMIN_PASSWORD=admin123

# --- WhatsApp OTP (set OTP_DEV_MODE=true to skip WhatsApp + accept OTP_DEV_CODE) ---
OTP_DEV_MODE=false
OTP_DEV_CODE=123456
WHATSAPP_API_URL=https://whatsapp-api-production-807b.up.railway.app
WHATSAPP_OTP_SESSION_ID=a12f37fe-aed1-4ef7-994f-3d21673b08df
WHATSAPP_OTP_TEMPLATE_ID=cd365b8d-802a-4e4d-b8dc-97a8286cad15
WHATSAPP_OTP_TEMPLATE_NAME=OTP Verification

# --- Razorpay payouts (leave PAYOUT_DEV_MODE=true to skip real payouts) ---
PAYOUT_DEV_MODE=true
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_ACCOUNT_NUMBER=

# --- CORS (comma separated) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,https://cashbee.app

# --- Rate limiting backend (use redis://... in production) ---
RATELIMIT_STORAGE_URI=memory://
