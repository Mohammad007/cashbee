# Copy to .env for local dev. On Railway, set these as service Variables instead.

# --- Core (CHANGE THESE IN PRODUCTION) ---
SECRET_KEY=change-me-in-production
JWT_SECRET=change-me-jwt-secret
JWT_EXPIRY_DAYS=30

# --- Admin login (admin panel / console) ---
ADMIN_EMAIL=admin@cashbee.app
ADMIN_PASSWORD=admin123

# --- Google Play Billing (verify in-app membership/boost purchases) ---
# The package name of your published app + path to the Google service-account
# JSON (with Play Developer API access). Leave blank to keep purchases disabled.
GOOGLE_PLAY_PACKAGE_NAME=com.cashbee.cashbee
GOOGLE_SERVICE_ACCOUNT_FILE=

# --- CORS (comma separated). Add your Railway domain + app/site origins. ---
CORS_ORIGINS=http://localhost:3000,https://your-app.up.railway.app

# --- Persistent data: point at a mounted Railway Volume so data survives redeploys ---
# DB_DIR=/data

# --- Rate limiting (use redis://... if you add a Redis plugin) ---
RATELIMIT_STORAGE_URI=memory://
